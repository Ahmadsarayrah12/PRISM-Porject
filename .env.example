# ─────────────────────────────────────────────────────────────
# Prism Media — Environment Variables Template
# انسخ هذا الملف باسم .env وعبّئ القيم الحقيقية
# ─────────────────────────────────────────────────────────────

# Google Cloud Project
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# مسار مفتاح حساب الخدمة (لا ترفعه لـ Git أو Docker)
GOOGLE_APPLICATION_CREDENTIALS=./key.json

# منفذ الخادم (Cloud Run يستخدم 8080 افتراضياً)
PORT=8080

# بيئة التشغيل: development | production
NODE_ENV=development

# CORS — النطاق المسموح له بالاتصال بالـ API
# في التطوير: http://localhost:8080
# في الإنتاج: https://your-domain.com
ALLOWED_ORIGIN=http://localhost:8080

# ─────────────────────────────────────────────────────────────
# Google Cloud Storage — لدعم ملفات الوسائط الكبيرة (> 10 MB)
# اتركه فارغاً لاستخدام الإرسال المباشر فقط (حتى 10 MB)
# ─────────────────────────────────────────────────────────────
# GCS_BUCKET=your-gcs-bucket-name
